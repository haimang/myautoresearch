{
  "domain": "fx_spot",
  "name": "spot-route-surface",
  "version": "1.0",
  "description": "Current quote-window route search space for import/export portfolio spot FX exploration.",
  "protocol": {
    "eval_level": null,
    "eval_opponent": null,
    "is_benchmark": false
  },
  "axes": {
    "treasury_scenario": {
      "type": "categorical",
      "values": [
        "cn_exporter_core",
        "usd_importer_mix",
        "global_diversified",
        "asia_procurement_hub"
      ],
      "scale": "linear",
      "role": "strategy",
      "allow_continuation": false,
      "description": "Treasury portfolio / liquidity-floor scenario used to materialize realistic holdings."
    },
    "sell_currency": {
      "type": "categorical",
      "values": ["CNY", "USD", "EUR", "JPY", "HKD", "SGD", "GBP", "AUD", "MXN"],
      "scale": "linear",
      "role": "strategy",
      "allow_continuation": false,
      "description": "Currency to convert from available surplus above the liquidity floor."
    },
    "buy_currency": {
      "type": "categorical",
      "values": ["CNY", "USD"],
      "scale": "linear",
      "role": "strategy",
      "allow_continuation": false,
      "description": "Currency to receive in the mocked spot route."
    },
    "route_template": {
      "type": "categorical",
      "values": ["direct", "via_usd", "via_eur", "via_hkd", "via_sgd"],
      "scale": "linear",
      "role": "strategy",
      "allow_continuation": false,
      "description": "Direct conversion or one intermediate bridge leg."
    },
    "rebalance_fraction": {
      "type": "float",
      "values": [0.15, 0.25, 0.4, 0.6, 0.75],
      "scale": "linear",
      "role": "execution",
      "allow_continuation": false,
      "description": "Fraction of sell-currency surplus to convert."
    },
    "sell_amount_mode": {
      "type": "categorical",
      "values": ["surplus_fraction", "explicit_ratio", "floor_probe"],
      "scale": "linear",
      "role": "execution",
      "allow_continuation": false,
      "description": "How the first-leg sell amount is derived; v23 adds explicit and floor-probe modes to activate constraints."
    },
    "sell_amount_ratio": {
      "type": "float",
      "values": [0.0, 0.15, 0.35, 0.6, 0.9, 1.1],
      "scale": "linear",
      "role": "execution",
      "allow_continuation": false,
      "description": "Share of current sell-currency holding used when sell_amount_mode=explicit_ratio."
    },
    "floor_buffer_target": {
      "type": "float",
      "values": [-0.05, 0.0, 0.05, 0.15],
      "scale": "linear",
      "role": "risk",
      "allow_continuation": false,
      "description": "Target post-trade buffer over liquidity floor when sell_amount_mode=floor_probe."
    },
    "max_legs": {
      "type": "int",
      "values": [2],
      "scale": "linear",
      "role": "risk",
      "allow_continuation": false,
      "description": "Maximum allowed route length."
    },
    "provider": {
      "type": "categorical",
      "values": ["mock"],
      "scale": "linear",
      "role": "provider",
      "allow_continuation": false,
      "description": "Quote provider adapter."
    },
    "quote_scenario": {
      "type": "categorical",
      "values": [
        "base",
        "wide_spread",
        "short_validity",
        "cn_exporter",
        "asia_hub",
        "usd_liquidity",
        "europe_corridor",
        "latam_volatility",
        "uplift_corridor",
        "constraint_stress"
      ],
      "scale": "linear",
      "role": "provider",
      "allow_continuation": false,
      "description": "Deterministic local quote-surface scenario for mock tests."
    }
  }
}
