{
  "domain": "fx_spot",
  "name": "spot-route-selector",
  "version": "1.0",
  "search_space_ref": {"domain": "fx_spot", "name": "spot-route-surface", "version": "1.0"},
  "stage_policy_ref": {"domain": "fx_spot", "name": "single-window", "version": "1.0"},
  "branch_policy_ref": {"domain": "fx_spot", "name": "no-branch", "version": "1.0"},
  "candidate_kinds": {
